# Base RPC (public endpoint works for reads, use Alchemy/Infura for writes)
BASE_RPC_URL=https://mainnet.base.org

# Agent wallet private key (0x-prefixed)
PRIVATE_KEY=0x...

# ── Mainnet contract addresses (from forge script output) ──
VAULT_ADDRESS=0x...
FACTORY_ADDRESS=0x...
REGISTRY_ADDRESS=0x...

# ── Testnet contract addresses (Base Sepolia — used with --testnet flag) ──
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VAULT_ADDRESS_TESTNET=0x...
FACTORY_ADDRESS_TESTNET=0x...
REGISTRY_ADDRESS_TESTNET=0x...

# Pinata (IPFS metadata for syndicate descriptions)
PINATA_API_KEY=
PINATA_GATEWAY=https://gateway.pinata.cloud

# The Graph subgraph (for syndicate discovery — optional, falls back to on-chain)
SUBGRAPH_URL=
