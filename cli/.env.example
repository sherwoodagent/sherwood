# ── RPC URLs ──
# Public endpoints work for reads, use Alchemy/Infura for writes
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── User Config (prefer `sherwood config set` over env vars) ──
# Private key: `sherwood config set --private-key 0x...`
# Vault:       `sherwood config set --vault 0x...` (auto-saved on `syndicate create`)
# Agent ID:    auto-saved on `sherwood identity mint`
#
# Env vars still work as fallback:
PRIVATE_KEY=0x...

# ── External API Keys ──
VENICE_API_KEY=

# ── IPFS ──
# Gateway for fetching IPFS content (reads only — uploads go through Sherwood API)
PINATA_GATEWAY=https://sherwood.mypinata.cloud
# Override upload API URL (defaults to https://sherwood.sh/api/ipfs/upload)
# SHERWOOD_API_URL=http://localhost:3000

# The Graph subgraph (optional — falls back to on-chain reads)
SUBGRAPH_URL=

# XMTP (chat) — uses PRIVATE_KEY for identity
# Optional: bot wallet for dashboard read access (--public-chat)
DASHBOARD_SPECTATOR_ADDRESS=
