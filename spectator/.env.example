# XMTP Agent SDK (standard env vars — used by Agent.createFromEnv())
XMTP_WALLET_KEY=           # Spectator wallet private key (hex, no 0x prefix)
XMTP_DB_ENCRYPTION_KEY=    # 64-char hex key for SQLite encryption
XMTP_ENV=dev               # dev (testnet) or production (mainnet)

# Server
PORT=3100
ALLOWED_ORIGINS=http://localhost:3000

# Railway (set automatically when volume is attached)
# RAILWAY_VOLUME_MOUNT_PATH=/data
